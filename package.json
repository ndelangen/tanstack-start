{
  "name": "tanstack-cli",
  "private": true,
  "type": "module",
  "scripts": {
    "app:build": "vite build",
    "app:dev": "vite dev --port 3000",
    "app:preview": "vite preview",
    "biome:check": "biome check . --write",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint . --fix",
    "convex:dev": "bun run migrations:dev-strict && convex dev",
    "convex:deploy": "convex deploy",
    "netlify": "bunx netlify",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "check:convex-skip": "node scripts/assert-no-convex-skip-in-domain-db.mjs",
    "generate": "bun run ./scripts/generate.ts",
    "migrations:dev-strict": "bun run ./scripts/migration-guards.ts dev-strict 300000 2000",
    "migrations:run-local-required": "bun run migrations:dev-strict",
    "migrations:deploy": "bun run ./scripts/migration-guards.ts deploy 2700000 5000 --prod",
    "migrations:narrow-check": "bun run ./scripts/migration-guards.ts narrow-check --prod",
    "capture": "bun run ./scripts/capture.ts",
    "proof:typecheck": "tsc --noEmit -p workers/proof/tsconfig.json",
    "proof:test": "vitest run workers/proof convex/lib/assetPublishingProof.test.ts",
    "proof:assets": "vite build --config workers/proof/vite.config.ts",
    "proof:browser-regression": "bun run proof:assets && bun run build-storybook && bun run workers/proof/browser-regression.ts",
    "proof:dry-run": "bun run proof:assets && wrangler deploy --dry-run --config workers/proof/wrangler.jsonc",
    "build-storybook": "storybook build",
    "local-capture": "storybook build && LOCAL=true bun run ./scripts/capture.ts",
    "storybook": "storybook dev -p 6006",
    "e2e:local": "bash ./scripts/e2e-local.sh",
    "e2e:test": "bash ./scripts/e2e-playwright.sh",
    "e2e:seed": "npx convex run e2e:seedBaseline '{\"ownerEmail\":\"e2e-user-a@example.com\"}'"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.94",
    "@convex-dev/migrations": "^0.3.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/caladea": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "clsx": "^2.1.1",
    "convex": "^1.42.0",
    "crypto-js": "^4.2.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.21.0",
    "markdown-to-jsx": "^9.8.2",
    "pdf-lib": "1.17.1",
    "react": "^19.2.7",
    "react-children-utilities": "^2.10.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "three": "^0.185.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/playwright": "1.3.0",
    "@cloudflare/workers-types": "^5.20260715.1",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tanstack/devtools-vite": "^0.8.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "cli-progress": "^3.12.0",
    "convex-test": "^0.0.54",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "recursive-readdir-files": "^2.3.2",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.111.0"
  },
  "packageManager": "bun@1.3.14"
}
