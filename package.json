{
  "name": "tanstack-cli",
  "private": true,
  "type": "module",
  "scripts": {
    "app:build": "vite build",
    "app:dev": "vite dev --port 3000",
    "app:preview": "vite preview",
    "biome:check": "biome check . --write",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint . --fix",
    "db": "supabase",
    "db:migration": "supabase migration new",
    "db:pull": "supabase db pull",
    "db:push": "supabase db push",
    "db:schemas": "bun run scripts/db-sync-data-schema.ts",
    "db:types": "supabase gen types typescript --project-id dgisrcsauchycqegqwty > src/app/db/core/types.ts",
    "netlify": "netlify",
    "test": "vitest run",
    "generate": "bun run ./scripts/generate.ts",
    "capture": "bun run ./scripts/capture.ts",
    "build-storybook": "storybook build",
    "local-capture": "storybook build && LOCAL=true bun run ./scripts/capture.ts",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "markdown-to-jsx": "^9.7.6",
    "react": "^19.2.0",
    "react-children-utilities": "^2.10.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/bun": "^1.3.10",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cli-progress": "^3.12.0",
    "jsdom": "^27.0.0",
    "netlify-cli": "^24.0.1",
    "playwright": "^1.58.2",
    "recursive-readdir-files": "^2.3.2",
    "storybook": "^10.2.15",
    "supabase": "^2.77.0",
    "typescript": "^5.9.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "packageManager": "bun@1.1.38"
}
