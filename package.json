{
  "name": "tanstack-cli",
  "private": true,
  "type": "module",
  "scripts": {
    "app:build": "vite build",
    "app:dev": "vite dev --port 3000",
    "app:preview": "vite preview",
    "biome:check": "biome check . --write",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint . --fix",
    "convex:dev": "bun run migrations:dev-strict && convex dev",
    "convex:deploy": "convex deploy",
    "netlify": "bunx netlify",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "check:convex-skip": "node scripts/assert-no-convex-skip-in-domain-db.mjs",
    "generate": "bun run ./scripts/generate.ts",
    "migrations:dev-strict": "bun run ./scripts/migration-guards.ts dev-strict 300000 2000",
    "migrations:run-local-required": "bun run migrations:dev-strict",
    "migrations:deploy": "bun run ./scripts/migration-guards.ts deploy 2700000 5000 --prod",
    "migrations:narrow-check": "bun run ./scripts/migration-guards.ts narrow-check --prod",
    "capture": "bun run ./scripts/capture.ts",
    "build-storybook": "storybook build",
    "local-capture": "storybook build && LOCAL=true bun run ./scripts/capture.ts",
    "storybook": "storybook dev -p 6006",
    "e2e:local": "bash ./scripts/e2e-local.sh",
    "e2e:test": "bash ./scripts/e2e-playwright.sh",
    "e2e:seed": "npx convex run e2e:seedBaseline '{\"ownerEmail\":\"e2e-user-a@example.com\"}'"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/migrations": "^0.3.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.3",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.5",
    "@tanstack/router-plugin": "^1.167.4",
    "clsx": "^2.1.1",
    "convex": "^1.34.0",
    "crypto-js": "^4.2.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^1.6.0",
    "markdown-to-jsx": "^9.7.13",
    "react": "^19.2.4",
    "react-children-utilities": "^2.10.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tanstack/devtools-vite": "^0.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cli-progress": "^3.12.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "recursive-readdir-files": "^2.3.2",
    "storybook": "^10.3.3",
    "typescript": "^6.0.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "bun@1.1.38"
}
